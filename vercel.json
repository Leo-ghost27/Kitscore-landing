{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index" },
    { "source": "/p/:slug*", "destination": "/app/p?slug=:slug*" },
    { "source": "/badge/:slug*", "destination": "/api/badge?slug=:slug*" },
    { "source": "/media-kit/:slug*", "destination": "/app/evekit?slug=:slug*" },
    { "source": "/api/tiktok-oauth", "destination": "/api/oauth?provider=tiktok" },
    { "source": "/api/youtube-oauth-callback", "destination": "/api/oauth?provider=youtube" },
    { "source": "/api/twitch-oauth", "destination": "/api/oauth?provider=twitch" },
    { "source": "/api/instagram-oauth", "destination": "/api/oauth?provider=instagram" }
  ],
  "redirects": [
    { "source": "/ek/:slug*", "destination": "/media-kit/:slug*", "permanent": true }
  ],
  "crons": [
    { "path": "/api/cron?job=evidence-nudges", "schedule": "0 9 * * 1" },
    { "path": "/api/cron?job=twitch-validate", "schedule": "0 4 * * *" },
    { "path": "/api/cron?job=youtube-resync", "schedule": "0 5 * * *" },
    { "path": "/api/cron?job=tiktok-resync", "schedule": "0 6 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/:path*.(png|jpg|svg|ico|xml|txt|webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
